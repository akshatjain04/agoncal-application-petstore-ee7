package org.agoncal.application.petstore.model;
import org.junit.Before;
import org.junit.Test;
import org.junit.experimental.categories.Category;
import static org.junit.Assert.*;
import javax.persistence.CascadeType;
import javax.persistence.Column;
import javax.persistence.Embeddable;
import javax.persistence.ManyToOne;
import javax.validation.constraints.NotNull;
import javax.validation.constraints.Size;
import java.io.Serializable;
import java.util.Objects;

package org.agoncal.application.petstore.model
public class AddressEqualsTest {
    private Address addr1;
    private Address addr2;
    private Country country1;
    private Country country2;
    @Before
    public void init() {
        country1 = new Country("US", "United States", "United States", "USA", "1");
        country2 = new Country("CA", "Canada", "Canada", "CAN", "2");
    }
    @Category(Categories.valid.class)
    @Test
    public void testEqualsForEqualAddresses() {
        addr1 = new Address("123 Main St.", "Springfield", "12345", country1);
        addr2 = new Address("123 Main St.", "Springfield", "12345", country1);
        assertTrue(addr1.equals(addr2));
    }
    @Category(Categories.valid.class)
    @Test
    public void testEqualsForDifferentAddresses() {
        addr1 = new Address("123 Main St.", "Springfield", "12345", country1);
        addr2 = new Address("456 Elm St.", "Ridgefield", "67890", country2);
        assertFalse(addr1.equals(addr2));
    }
    @Category(Categories.invalid.class)
    @Test
    public void testEqualsForNullValue() {
        addr1 = new Address("123 Main St.", "Springfield", "12345", country1);
        assertFalse(addr1.equals(null));
    }
 
    @Category(Categories.invalid.class)
    @Test
    public void testEqualsForNonAddressObject() {
        addr1 = new Address("123 Main St.", "Springfield", "12345", country1);
        Object nonAddressObject = new Object();
        assertFalse(addr1.equals(nonAddressObject));
    }
} 