package org.agoncal.application.petstore.model;
import org.junit.*;
import static org.junit.Assert.*;
import org.junit.experimental.categories.Category;
import org.agoncal.application.petstore.Categories;
import javax.persistence.*;
import javax.validation.constraints.NotNull;
import javax.validation.constraints.Size;
import javax.xml.bind.annotation.XmlRootElement;
import java.io.Serializable;
import java.util.Objects;

public class CountryEqualsTest {
    @Test
    @Category(Categories.valid.class)
    public void testEqualityWithSameObject() {
        Country country1 = new Country("USA", "United States", "USA", "UsaCode", "1");
        assertTrue(country1.equals(country1));
    }
    @Test
    @Category(Categories.valid.class)
    public void testEqualityWithDifferentObjectSameIsoCode() {
        Country country1 = new Country("USA", "United States", "USA", "UsaCode", "1");
        Country country2 = new Country("USA", "United States of America", "US", "UsaCode", "2");
        assertTrue(country1.equals(country2));
    }
    @Test
    @Category(Categories.valid.class)
    public void testingEqualityWithDifferentObjectDifferentIsoCode() {
        Country country1 = new Country("USA", "United States", "USA", "UsaCode", "1");
        Country country2 = new Country("AUS", "Australia", "AUS", "AusCode", "3");
        assertFalse(country1.equals(country2));
    }
    @Test
    @Category(Categories.invalid.class)
    public void testEqualityWithNull() {
        Country country1 = new Country("USA", "United States", "USA", "UsaCode", "1");
        assertFalse(country1.equals(null));
    }
    @Test
    @Category(Categories.invalid.class)
    public void testEqualityWithDifferentClassType() {
        Country country = new Country("USA", "United States", "USA", "UsaCode", "1");
        String str = "Some String";
        assertFalse(country.equals(str));
    }
}